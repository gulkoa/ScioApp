# MongoDB Atlas credentials
MONGODB_USERNAME=your_mongodb_username
MONGODB_PASSWORD=your_mongodb_password

# Auth0 — from your Auth0 tenant dashboard
AUTH0_DOMAIN=dev-xxxxx.us.auth0.com
AUTH0_AUDIENCE=https://your-app.example.com/api
AUTH0_MGMT_CLIENT_ID=your_m2m_client_id
AUTH0_MGMT_CLIENT_SECRET=your_m2m_client_secret
AUTH0_AUTHZ_AUDIENCE=urn:auth0-authz-api
AUTH0_AUTHZ_EXT_TOKEN=your_authz_extension_token

# Server
PORT=5000
NODE_ENV=development
